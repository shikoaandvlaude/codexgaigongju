# ============================================================
# Bai Auto-Hunt Agent — 环境变量配置
# 复制为 .env 并填入你的 Key
# ============================================================

# LLM API Key（三选一，优先级从高到低）
DEEPSEEK_API_KEY=sk-你的DeepSeek-Key
# OPENAI_API_KEY=sk-你的OpenAI-Key
# XAI_API_KEY=xai-你的Grok-Key

# LLM 配置覆盖（可选）
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Ollama（如果用本地模型）
# OLLAMA_HOST=http://localhost:11434
# BRAIN_PROVIDER=ollama

# Claude API（用于 brain.py 多模型推理层）
# ANTHROPIC_API_KEY=sk-ant-你的Key

# FOFA（资产发现，可选）
# FOFA_EMAIL=你的邮箱
# FOFA_KEY=你的Key

# GitHub Token（GitHub dorking，可选）
# GITHUB_TOKEN=ghp_你的token

# HackerOne（可选，用于自动拉取 scope）
# HACKERONE_USERNAME=你的H1用户名
# HACKERONE_API_TOKEN=你的H1-API-Token
