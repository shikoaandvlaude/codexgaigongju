# ============================================================
# Bai-codeagent 白盒审计服务 — 环境变量配置
# 复制为 .env 并填入你的 Key
# ============================================================

# 服务端口（默认 3000）
PORT=3000

# ============================================================
# GitHub（用于发现候选目标 + 拉取源码镜像）
# 不配置也能跑（会走 sample-fallback），但搜索结果会受限
# ============================================================
GITHUB_TOKEN=ghp_你的GitHub个人访问令牌

# 限制搜索范围到特定 org（可选）
# GITHUB_OWNER_FILTER=target-org

# ============================================================
# LLM 复核（规则层之后的 AI 二次确认）
# 不配置时规则层仍能出结果，但无 LLM 降噪
# 支持: openai / deepseek / anthropic / ollama
# ============================================================

# OpenAI 兼容接口（DeepSeek / OpenAI / 本地 LLM）
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-你的DeepSeek或OpenAI-Key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 或者用 Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-你的Claude-Key
# LLM_MODEL=claude-sonnet-4-20250514

# 或者用本地 Ollama
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5-coder:32b

# ============================================================
# FOFA 资产发现（可选，用于补充外部资产面）
# ============================================================
# FOFA_EMAIL=你的FOFA邮箱
# FOFA_KEY=你的FOFA-API-Key

# ============================================================
# 运行模式
# ============================================================

# 默认 hunt 模式: hackerone /護网 / general
# HUNT_MODE=hackerone

# 默认 program profile: cms / kubernetes / general-oss / fintech / saas
# PROGRAM_PROFILE=fintech
